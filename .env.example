SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=DBT_USER
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=TRANSFORM_WH
SNOWFLAKE_DATABASE=SF_UDP_POC
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_SCHEMA=RAW

# Used by the Snowflake Terraform provider.
SNOWFLAKE_ORGANIZATION_NAME=
SNOWFLAKE_ACCOUNT_NAME=

# Terraform reads input variables from TF_VAR_* environment variables.
TF_VAR_snowflake_organization_name=
TF_VAR_snowflake_account_name=
TF_VAR_snowflake_user=
TF_VAR_snowflake_password=
TF_VAR_dbt_user_password=

# Optional, but recommended to raise Socrata API rate limits.
SOCRATA_APP_TOKEN=

# Optional: point Python clients at a local CA bundle if antivirus or corporate
# HTTPS inspection is installed on the machine.
REQUESTS_CA_BUNDLE=
SSL_CERT_FILE=
